# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (career AI chat + resume parsing)
ANTHROPIC_API_KEY=

# Resend (transcript + feedback email)
RESEND_API_KEY=

# Paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_CANDIDATE_BASIC_PRICE_ID=
PADDLE_CANDIDATE_PRO_PRICE_ID=
PADDLE_EMPLOYER_STARTER_PRICE_ID=
PADDLE_EMPLOYER_GROWTH_PRICE_ID=
PADDLE_EMPLOYER_SCALE_PRICE_ID=

# Cloudflare Turnstile (public chatbot bot protection).
# Optional: the chat works without these; when set, the public chat surface adds
# an invisible/managed bot check. Site key is public; secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cron secret for the transcript-delivery safety-net sweep (/api/cron/*).
# Vercel Cron sends it as a Bearer token; without it the sweep no-ops and the
# browser beacon path still delivers transcripts.
CRON_SECRET=

# App — local dev uses localhost; production is https://roleboost.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
