# Public chatbot bot protection uses Vercel BotID (invisible; no keys needed).
# BotID Basic activates automatically once deployed on Vercel. Enable Deep
# Analysis in the Vercel dashboard (Firewall > Rules) for stronger detection.
# Edge rate limiting uses the Vercel WAF (@vercel/firewall). Create rules named
# "chat", "schedule", and "deliver" in Firewall > Rules; the code no-ops until
# they exist. Neither needs an env var here.

# Cron secret for the transcript-delivery safety-net sweep (/api/cron/*).
# Vercel Cron sends it as a Bearer token; without it the sweep no-ops and the
# browser beacon path still delivers transcripts.
CRON_SECRET=

# App — local dev uses localhost; production is https://roleboost.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
